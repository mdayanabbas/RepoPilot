# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Local environment and secrets
.env
.env.*
!.env.example

# Local databases
*.db
*.sqlite
*.sqlite3
repopilot.db

# Logs and temporary files
*.log
.tmp/
tmp/
temp/

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# RepoPilot runtime storage
storage/workspaces/*
storage/traces/*
storage/logs/*
!storage/workspaces/.gitkeep
!storage/traces/.gitkeep
!storage/logs/.gitkeep
